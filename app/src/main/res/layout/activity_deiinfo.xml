            android:layout_marginEnd="20dp"
            android:textColor="@color/app_color"
            android:textSize="@dimen/_12sdp"

            app:layout_constraintBottom_toBottomOf="@+id/culturalText"
            app:layout_constraintEnd_toEndOf="parent"
